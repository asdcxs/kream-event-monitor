# 텔레그램 봇 토큰 — @BotFather 에서 /newbot 으로 발급
TELEGRAM_BOT_TOKEN=

# 봇 메시지를 받을 chat_id
# 발급 방법:
#   1) 봇과 채팅 시작 (메시지 한 번 보내기)
#   2) 브라우저에서 열기: https://api.telegram.org/bot<TOKEN>/getUpdates
#   3) "chat":{"id":XXXXXXXX} 값이 chat_id
TELEGRAM_CHAT_ID=

# (선택) 크림 이메일 로그인 — 빠른배송 가격 직접조회용. gitignore됨, 커밋 안 함.
# 네이버/애플 소셜로그인 계정이면 크림 "비밀번호 찾기"로 이메일 로그인용 비번 발급 필요.
KREAM_EMAIL=
KREAM_PASSWORD=
